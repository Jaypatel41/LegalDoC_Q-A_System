# ============ LLM provider ============
# choose one: anthropic | openai | local
LLM_PROVIDER=anthropic

# Anthropic (Claude) — recommended default, most accurate for grounded legal QA
ANTHROPIC_API_KEY=sk-ant-...
# model id (see src/llm.py for options). claude-haiku-4-5 is cheap+fast for RAG.
ANTHROPIC_MODEL=claude-haiku-4-5

# OpenAI (alternative)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Local (Ollama / llama.cpp OpenAI-compatible endpoint)
LOCAL_BASE_URL=http://localhost:11434/v1
LOCAL_MODEL=llama3:8b

# ============ misc ============
# set to 1 to force offline/deterministic stub LLM (for CI / no-key demos)
USE_STUB_LLM=0
